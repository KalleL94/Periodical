# Normalise line endings so the repo stops carrying a mix of CRLF and LF.
#
# Before this file, 55 tracked files were CRLF and 178 were LF. Any tool that
# read a file and wrote it back (a formatter, a script, an editor on another
# platform) silently flipped its endings, turning a two-line change into a
# whole-file diff. The commit that adds this file renormalises everything to LF
# in one place, so those diffs stay small from here on.
#
# LF is the right target: the app runs on Linux, is deployed by shell scripts,
# and is built in Docker.

# Everything text-like is normalised in the repo and checked out as LF.
* text=auto eol=lf

# Shell scripts and the systemd unit must be LF or they break at runtime.
*.sh            text eol=lf
*.service       text eol=lf
Dockerfile      text eol=lf
Makefile        text eol=lf

# Binary: never touch these.
*.woff2         binary
*.db            binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.xlsx          binary
