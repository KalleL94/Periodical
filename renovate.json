{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Stockholm",
  "poetry": {
    "enabled": false
  },
  "pip_requirements": {
    "enabled": false
  },
  "pip-compile": {
    "enabled": true
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Bump ruff in pyproject.toml and .pre-commit-config.yaml together so the pins stay in sync.",
      "matchPackageNames": ["ruff", "astral-sh/ruff-pre-commit"],
      "groupName": "ruff"
    },
    {
      "description": "Hold the Python version on 3.14 to match the production venv and the compiled lockfile. Bump deliberately as a coordinated change (prod venv + recompile + CI + Dockerfile).",
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "matchManagers": ["pip-compile"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor and patch dependencies",
      "automerge": false
    },
    {
      "matchManagers": ["pip-compile"],
      "matchUpdateTypes": ["major"],
      "groupName": "major dependencies"
    }
  ]
}
